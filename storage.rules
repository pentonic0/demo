rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'pentonic.me@gmail.com' || 
         (firestore.exists(/databases/ai-studio-62a53afb-e7db-428f-8071-bac429385a24/documents/users/$(request.auth.uid)) &&
          firestore.get(/databases/ai-studio-62a53afb-e7db-428f-8071-bac429385a24/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // Allow public read access to all files
    match /{allPaths=**} {
      allow read: if true;
      // Only admins can upload, update, or delete files
      allow write: if isAdmin();
    }
  }
}
